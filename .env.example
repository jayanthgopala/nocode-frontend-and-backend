# --- Core ---
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# --- Frontend CORS allowlist ---
# Comma-separated list of EXACT origins. No wildcards. Include scheme.
# e.g. https://app.sumantheluri.tech,https://admin.sumantheluri.tech
CORS_ORIGINS=https://app.sumantheluri.tech

# --- Main backend (token verification) ---
# This service forwards every request's auth token to the main backend's
# verify endpoint and trusts whatever user/role it returns. The main app
# stays the single source of truth for who can log in.
#
# Use the INTERNAL Docker hostname when both services run on the same VPS:
#   MAIN_BACKEND_URL=http://<container-or-service-name>:<port>
# Otherwise, use the public URL (slower, less reliable).
MAIN_BACKEND_URL=http://main-backend:3000
MAIN_BACKEND_VERIFY_PATH=/api/auth/me

# Header the frontend uses to send the token. We forward this header
# byte-for-byte to the main backend (with the same name + prefix).
AUTH_HEADER_NAME=Authorization
AUTH_HEADER_PREFIX=Bearer

# Field paths in the verify endpoint's JSON response. The middleware
# unwraps `{user:{...}}`, `{data:{...}}`, or root-level objects.
AUTH_USER_ID_FIELD=id
AUTH_USER_EMAIL_FIELD=email
AUTH_USER_ROLE_FIELD=role

# Comma-separated list of roles allowed to call /api/exports. Compared
# case-insensitively against AUTH_USER_ROLE_FIELD.
ALLOWED_ROLES=admin,tpo

# --- NocoDB ---
NOCODB_URL=https://nocode.sumantheluri.tech
# IMPORTANT: paste the real token in Dokploy's Environment tab, NEVER in the repo.
NOCODB_TOKEN=replace-me
NOCODB_BASE_ID=pqyrwsdgl7wwsij

# --- Limits ---
MAX_TABLES_PER_EXPORT=10
MAX_ROWS_PER_TABLE=100000
RATE_LIMIT_EXPORTS_PER_HOUR=10
RATE_LIMIT_LISTS_PER_HOUR=60

# --- Optional verification cache ---
# Set 1..60 to cache successful verifications for that many seconds (per token).
# 0 = disabled (default; recommended unless you measure verify-endpoint pressure).
VERIFY_CACHE_TTL_SECONDS=0
