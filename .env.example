# --- Core ---
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# --- Frontend CORS allowlist ---
# Comma-separated list of EXACT origins. No wildcards. Include scheme.
CORS_ORIGINS=https://app.sumantheluri.tech

# --- Auth (local JWT) ---
# JWT_SECRET: long random string. Generate with: openssl rand -base64 64
# Must be at least 32 characters. Treat as a top-tier secret.
JWT_SECRET=replace-with-openssl-rand-base64-64
JWT_EXPIRES_IN=12h
JWT_ISSUER=placement-exports

# Comma-separated list of roles allowed to call /api/exports. Compared case-insensitively.
ALLOWED_ROLES=admin,tpo

# Users database (single-line JSON array).
# Each entry: { "email": "...", "passwordHash": "<bcrypt>", "role": "admin|tpo|...", "id": "optional" }
# Generate a hash: node scripts/hash-password.js 'theirPassword'
# IMPORTANT: paste the real value in Dokploy's Environment tab. Do NOT commit real hashes.
USERS_JSON=[{"email":"admin@example.com","passwordHash":"$2a$12$replace_with_real_bcrypt_hash","role":"admin"}]

# --- NocoDB ---
NOCODB_URL=https://nocode.sumantheluri.tech
NOCODB_TOKEN=replace-me
NOCODB_BASE_ID=pqyrwsdgl7wwsij

# --- Limits ---
MAX_TABLES_PER_EXPORT=10
MAX_ROWS_PER_TABLE=100000
RATE_LIMIT_EXPORTS_PER_HOUR=10
RATE_LIMIT_LISTS_PER_HOUR=60
RATE_LIMIT_LOGIN_PER_15MIN=10
